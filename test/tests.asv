classdef tests < matlab.unittest.TestCase

    methods(Test)

        function mach_test1(testCase)
            actual_mach = mach_test_func;
            testCase.verifyGreaterThanOrEqual(actual_mach, 1.7);
        end

        function sound_test(testCase)
            actual_sound = sound_test_func;
            testCase.verifyLessThan(actual_sound, 75);%EPNL
        end

        function ground_roll_test(testCase)
            actaul_ground_roll_distance = ground_roll_test_func;
            testCase.verifyLessThan(actaul_ground_roll_distance, 8000);%ft
        end

        function range_test(testCase)
            actual_range = range_test_func;
            testCase.verifyGreaterThanOrEqual(actual_range, 4000);%nm placeholder
        end

        function payload_test(testCase)
            actual_payload = payload_test_func;
            testCase.verifyGreaterThanOrEqual(actual_payload, 14000);%lbs
        end

        function fuel_cap_test(testCase)
            actual_fuel_cap = fuel_cap_test_func;
            testCase.verifyGreaterThanOrEqual(actual_fuel_cap, 14857);%gal
        end

        function stab_control_test(testCase)
            [trim, dr_xw_deg, dr_oei_deg, SM, roll_rate,Cl_p,Cn_beta]=Stability_Control_Requirements()
            testCase.verifyTrue(trim);
            testCase.verifyGreaterThanOrEqual(SM, 4);
            testCase.verifyLessThanOrEqual(SM, 7);
            testCase.verifyLessThan(dr_xw_deg, 20);
            testCase.verifyLessThan(dr_oei_deg, 20);
            testCase.verifyLessThan(Cl_p,0);
            testCase.verifyGreaterThan(Cn_beta,0);
            testCase.verifyGreaterThan(roll_rate,20);
        end
    end
end